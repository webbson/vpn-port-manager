# The only two env vars the app reads. Provider + router credentials are
# configured in the web UI (/setup on first boot, /settings afterwards) and
# stored encrypted in the SQLite database.

# Required: 16+ characters. Generate with: openssl rand -hex 32
# Do NOT change this after first boot — it is the AES-GCM key that wraps
# every stored secret. Changing it invalidates all encrypted settings.
APP_SECRET_KEY=change-me-to-a-long-random-string

# Optional (default: 3000). Web UI + API port.
PORT=3000

# Optional (default: /data/vpnportmanager.db). SQLite file path.
# DB_PATH=/data/vpnportmanager.db
